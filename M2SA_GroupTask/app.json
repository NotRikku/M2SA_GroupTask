{
  "expo": {
    "name": "Terra Mori",
    "slug": "M2SA_GroupTask",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Terra Mori.png",
    "scheme": "m2sagrouptask",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F0E4",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.M2SA_GroupTask"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Terra Mori.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F0E4",
          "dark": {
            "backgroundColor": "#F7F0E4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
